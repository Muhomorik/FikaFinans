<mah:MetroWindow
    x:Class="FikaFinans.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:FikaFinans.Wpf.ViewModels"
    xmlns:bankViews="clr-namespace:FikaFinans.Wpf.Views.Bank"
    xmlns:stepViews="clr-namespace:FikaFinans.Wpf.Views.Steps"
    Title="{Binding Title}"
    Width="1080"
    Height="720"
    MinWidth="1080"
    d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=True}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:EventToCommand EventName="Loaded" Command="{Binding LoadedCommand}" />
        <dxmvvm:CurrentWindowService ClosingCommand="{Binding WindowClosingCommand}" />
    </dxmvvm:Interaction.Behaviors>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings"
                    Style="{StaticResource ff.ButtonFlatStyle}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" Settings"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <DockPanel>

        <!-- ── Run bar ─────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource MahApps.Brushes.Gray10}"
                BorderBrush="{StaticResource MahApps.Brushes.Gray7}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Week picker -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Week"
                               Style="{StaticResource ff.SmallStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableWeeks}"
                              SelectedItem="{Binding SelectedWeek}"
                              Width="110"
                              mah:ControlsHelper.CornerRadius="4"/>
                </StackPanel>

                <!-- Family picker -->
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Family"
                               Style="{StaticResource ff.SmallStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding AvailableFamilies}"
                              SelectedItem="{Binding SelectedFamily}"
                              Width="120"
                              mah:ControlsHelper.CornerRadius="4"/>
                </StackPanel>

                <!-- Run all button -->
                <Button Grid.Row="0" Grid.Column="4"
                        Command="{Binding RunAllCommand}"
                        Style="{StaticResource ff.ButtonAccentStyle}"
                        Padding="16,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" Run all"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Stop button -->
                <Button Grid.Row="0" Grid.Column="6"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource ff.ButtonStyle}"
                        Padding="16,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71A;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" Stop"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Run ID + status (row 2, spans columns) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="7"
                            Orientation="Horizontal"
                            Margin="0,4,0,0">
                    <TextBlock Text="Run ID: "
                               Style="{StaticResource ff.SmallStyle}"/>
                    <TextBlock Text="{Binding RunId}"
                               Style="{StaticResource ff.SmallStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="   ·   Status: "
                               Style="{StaticResource ff.SmallStyle}"/>
                    <TextBlock Text="{Binding RunStatusText}"
                               Style="{StaticResource ff.SmallStyle}"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Status bar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource MahApps.Brushes.Gray10}"
                BorderBrush="{StaticResource MahApps.Brushes.Gray7}"
                BorderThickness="0,1,0,0"
                Padding="16,4">
            <TextBlock Text="{Binding StatusBarText}"
                       Style="{StaticResource ff.SmallStyle}"/>
        </Border>

        <!-- ── 11-tab pipeline strip ───────────────────────────────── -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- 0 · Bank -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="BankPip" Text="·"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" Bank" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <bankViews:BankView DataContext="{Binding BankTab}"/>
            </TabItem>

            <!-- 1 · Data loader -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step1Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 1 Data" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step1Tab}"/>
            </TabItem>

            <!-- 2 · Metrics -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step2Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 2 Metrics" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step2Tab}"/>
            </TabItem>

            <!-- 3 · Macro -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step3Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 3 Macro" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step3Tab}"/>
            </TabItem>

            <!-- 4 · Signal -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step4Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 4 Signal" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step4Tab}"/>
            </TabItem>

            <!-- 5 · Align -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step5Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 5 Align" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step5Tab}"/>
            </TabItem>

            <!-- 6 · Catalyst -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step6Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 6 Catalyst" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step6Tab}"/>
            </TabItem>

            <!-- 7 · Thesis -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step7Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 7 Thesis" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step7Tab}"/>
            </TabItem>

            <!-- 8 · Recommend -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step8Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 8 Recommend" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step8Tab}"/>
            </TabItem>

            <!-- 9 · Universe -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step9Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 9 Universe" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:Step9UniverseEnricherView DataContext="{Binding Step9Tab}"/>
            </TabItem>

            <!-- 10 · Portfolio -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Step10Tab.StatusPip, FallbackValue='·'}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text=" 10 Portfolio" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <stepViews:StepView DataContext="{Binding Step10Tab}"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</mah:MetroWindow>

<UserControl
    x:Class="FikaFinans.Wpf.Views.Charts.SignalsChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="360"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <DockPanel>

        <!-- Legend swatches above chart -->
        <ItemsControl DockPanel.Dock="Top"
                      ItemsSource="{Binding LegendItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Margin="0,0,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
                        <Rectangle Width="14" Height="3"
                                   Fill="{Binding Color}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Label}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Chart (axes configured in code-behind — DateTimeAxis has no parameterless ctor) -->
        <lvc:CartesianChart
            x:Name="Chart"
            Series="{Binding Series, RelativeSource={RelativeSource AncestorType=UserControl}}"
            AnimationsSpeed="0:0:0.15"/>
    </DockPanel>
</UserControl>

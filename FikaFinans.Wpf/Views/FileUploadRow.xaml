<UserControl
    x:Class="FikaFinans.Wpf.Views.FileUploadRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:FikaFinans.Wpf.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:FikaFinans.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:FileEntryViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="32"
    d:DesignWidth="720"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusToBrush" />
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border
        Padding="0,4"
        BorderBrush="{DynamicResource MahApps.Brushes.Control.Border}"
        BorderThickness="0,0,0,1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Compact baseline row: status · filename · description · size+uploaded · refresh  -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Status: small colored dot + label in matching color  -->
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    ToolTip="{Binding UploadedFileIdLabel}">
                    <Ellipse
                        Width="8"
                        Height="8"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center"
                        Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                        Text="{Binding StatusLabel}" />
                </StackPanel>

                <!--  Filename  -->
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="Consolas, Cascadia Code, Courier New"
                    FontWeight="SemiBold"
                    Text="{Binding LogicalName}"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding LocalPath}" />

                <!--  Short description of the file's content  -->
                <TextBlock
                    Grid.Column="2"
                    Margin="16,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Opacity="0.7"
                    Text="{Binding Description}"
                    TextTrimming="CharacterEllipsis" />

                <!--  Size + uploaded timestamp (foundry-side facts)  -->
                <TextBlock
                    Grid.Column="3"
                    Margin="12,0,8,0"
                    VerticalAlignment="Center"
                    FontFamily="Consolas, Cascadia Code, Courier New"
                    FontSize="12"
                    Opacity="0.7"
                    Text="{Binding FoundrySummaryLabel}" />

                <!--  Per-row force-refresh  -->
                <Button
                    Grid.Column="4"
                    Width="28"
                    Height="24"
                    Padding="0"
                    Command="{Binding RefreshThisCommand}"
                    Content="↻"
                    FontSize="13"
                    ToolTip="Force re-upload this file" />
            </Grid>

            <!--  Attention detail (only visible when Stale / Not uploaded / Missing)  -->
            <Grid
                Grid.Row="1"
                Margin="110,2,0,2"
                Visibility="{Binding IsAttention, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="12,0,8,0"
                    FontSize="11"
                    Opacity="0.55"
                    Text="Local:" />
                <TextBlock
                    Grid.Column="1"
                    FontFamily="Consolas, Cascadia Code, Courier New"
                    FontSize="11"
                    Opacity="0.75"
                    Text="{Binding LocalSummaryLabel}"
                    TextTrimming="CharacterEllipsis"
                    ToolTip="{Binding LocalPath}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>

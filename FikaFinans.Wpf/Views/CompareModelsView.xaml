<UserControl
    x:Class="FikaFinans.Wpf.Views.CompareModelsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:FikaFinans.Wpf.Views.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FikaFinans.Wpf.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:FikaFinans.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:CompareModelsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="900"
    d:DesignWidth="1500"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  File upload strip — compact one-row-per-file layout  -->
        <Border
            Grid.Row="0"
            Padding="12,10"
            Background="{DynamicResource MahApps.Brushes.Control.Background}"
            BorderBrush="{DynamicResource MahApps.Brushes.Control.Border}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Header: title · ⓘ legend tooltip · Refresh all  -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Foundry uploads" />

                    <!--  Status-legend reveal — hover for the four-state cheat sheet  -->
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Cursor="Help"
                        FontSize="14"
                        Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                        Text="ⓘ"
                        ToolTipService.InitialShowDelay="200"
                        ToolTipService.ShowDuration="20000">
                        <TextBlock.ToolTip>
                            <ToolTip Padding="10" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Fill="#2D9CDB" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#2D9CDB"
                                            Text="Fresh" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,0,4"
                                        VerticalAlignment="Center"
                                        Opacity="0.75"
                                        Text="local file matches what's uploaded" />

                                    <StackPanel
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Fill="#E07B00" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#E07B00"
                                            Text="Stale" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,0,0,4"
                                        VerticalAlignment="Center"
                                        Opacity="0.75"
                                        Text="local file edited since upload — next run re-uploads" />

                                    <StackPanel
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Margin="0,0,12,4"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Fill="#E07B00" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#E07B00"
                                            Text="Not uploaded" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,0,4"
                                        VerticalAlignment="Center"
                                        Opacity="0.75"
                                        Text="on disk but never uploaded — next run uploads" />

                                    <StackPanel
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Margin="0,0,12,0"
                                        Orientation="Horizontal">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Fill="#C1392B" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#C1392B"
                                            Text="Missing" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Opacity="0.75"
                                        Text="file not found on disk — run will fail" />
                                </Grid>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>

                    <Button
                        Grid.Column="3"
                        Padding="14,4"
                        Command="{Binding RefreshAllFilesCommand}"
                        Content="Refresh all" />
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Files}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:FileUploadRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!--  Question entry  -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                MinHeight="60"
                Margin="0,0,8,0"
                AcceptsReturn="True"
                Text="{Binding Question}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                mah:TextBoxHelper.Watermark="Ask a fund-portfolio question — runs through all models in parallel" />
            <Button
                Grid.Column="1"
                Padding="20,4"
                VerticalAlignment="Stretch"
                Command="{Binding RunComparisonCommand}"
                Content="Run on all models"
                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
        </Grid>

        <!--  Inline error banner  -->
        <Border
            Grid.Row="2"
            Margin="0,8,0,0"
            Padding="10,6"
            Background="#33C1392B"
            BorderBrush="#C1392B"
            BorderThickness="1"
            CornerRadius="2"
            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock
                Foreground="#C1392B"
                Text="{Binding ErrorMessage}"
                TextWrapping="Wrap" />
        </Border>

        <!--  Result panels (one per deployed model — see Docs/models.md)  -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <local:ModelResultPanel
                Grid.Column="0"
                Margin="0,0,6,0"
                DataContext="{Binding Run1}" />
            <local:ModelResultPanel
                Grid.Column="1"
                Margin="6,0,0,0"
                DataContext="{Binding Run2}" />
        </Grid>

        <!--  Bottom hint  -->
        <TextBlock
            Grid.Row="4"
            Margin="0,8,0,0"
            FontSize="11"
            Opacity="0.55"
            Text="Code Interpreter sessions take 60–120 s per model. Per-model failures don't abort the others. Settings (data folder) lives in the gear icon, top-right." />
    </Grid>
</UserControl>

<UserControl
    x:Class="FikaFinans.Wpf.Views.Steps.StepView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="clr-namespace:FikaFinans.Wpf.Views.Controls"
    xmlns:steps="clr-namespace:FikaFinans.Wpf.ViewModels.Steps"
    d:DataContext="{d:DesignInstance Type=steps:Step1DataLoaderViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="600"
    d:DesignWidth="1048"
    mc:Ignorable="d">

    <DockPanel Margin="16">

        <!-- ── Header row ───────────────────────────────────────────── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding HeaderText}"
                       Style="{StaticResource ff.TitleStyle}"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Command="{Binding EditConfigCommand}"
                    Style="{StaticResource ff.ButtonFlatStyle}"
                    Padding="12,4"
                    Content="Edit config…">
                <Button.Visibility>
                    <Binding Path="HasConfig">
                        <Binding.Converter>
                            <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                    </Binding>
                </Button.Visibility>
            </Button>

            <Button Grid.Column="3"
                    Command="{Binding SendToBankCommand}"
                    Style="{StaticResource ff.ButtonStyle}"
                    Padding="12,4">
                <Button.Visibility>
                    <Binding Path="HasBank">
                        <Binding.Converter>
                            <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                    </Binding>
                </Button.Visibility>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8AB;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" Send to bank" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="5"
                    Command="{Binding RunStepCommand}"
                    Style="{StaticResource ff.ButtonAccentStyle}"
                    Padding="16,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE768;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" Run step" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ── Error / log (collapsible, bottom) ───────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,8,0,0"
                Style="{StaticResource ff.PanelControlStyle}"
                Padding="8">
            <Expander Header="Errors / log"
                      IsExpanded="{Binding ErrorsExpanded}">
                <TextBox Text="{Binding ErrorText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         MaxHeight="100"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="11"
                         FontFamily="Consolas"
                         BorderThickness="0"
                         Background="Transparent"/>
            </Expander>
        </Border>

        <!-- ── Inputs / Run Status | Output viewer ─────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Inputs + run status -->
            <Border Grid.Column="0" Style="{StaticResource ff.PanelStyle}" Padding="12">
                <StackPanel>
                    <TextBlock Text="Run status"
                               Style="{StaticResource ff.SubheaderStyle}"
                               Margin="{StaticResource ff.LabelSpacing}"/>

                    <Grid Margin="{StaticResource ff.CompactSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Last run:" Style="{StaticResource ff.SmallStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LastRunText}" Style="{StaticResource ff.SmallStyle}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Duration:" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DurationText}" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Summary:" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OutputSummaryText}" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}" FontWeight="SemiBold" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StatusPip}" Style="{StaticResource ff.SmallStyle}" Margin="{StaticResource ff.CompactSpacing}" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <GridSplitter Grid.Column="1" Style="{StaticResource ff.SplitterStyle}"/>

            <!-- Right: Output viewer (Tree / Raw JSON toggle) -->
            <Border Grid.Column="2" Style="{StaticResource ff.PanelStyle}" Padding="0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="12,8,12,4">
                        <TextBlock Text="Output"
                                   Style="{StaticResource ff.SubheaderStyle}"
                                   VerticalAlignment="Center"/>
                        <RadioButton x:Name="TreeToggle"
                                     Content="Tree"
                                     GroupName="OutputMode"
                                     IsChecked="True"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center"
                                     FontSize="11"/>
                        <RadioButton x:Name="RawToggle"
                                     Content="Raw JSON"
                                     GroupName="OutputMode"
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center"
                                     FontSize="11"/>
                    </StackPanel>

                    <!-- Both views share the same cell; only one is Visible at a time -->
                    <Grid>
                        <controls:JsonTreeView JsonText="{Binding OutputJson, Mode=OneWay}">
                            <controls:JsonTreeView.Visibility>
                                <Binding ElementName="TreeToggle" Path="IsChecked">
                                    <Binding.Converter><BooleanToVisibilityConverter/></Binding.Converter>
                                </Binding>
                            </controls:JsonTreeView.Visibility>
                        </controls:JsonTreeView>

                        <controls:JsonRawView JsonText="{Binding OutputJson, Mode=OneWay}">
                            <controls:JsonRawView.Visibility>
                                <Binding ElementName="RawToggle" Path="IsChecked">
                                    <Binding.Converter><BooleanToVisibilityConverter/></Binding.Converter>
                                </Binding>
                            </controls:JsonRawView.Visibility>
                        </controls:JsonRawView>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>

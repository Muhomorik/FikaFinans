<UserControl
    x:Class="FikaFinans.Wpf.Views.Bank.BankView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:FikaFinans.Wpf.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:BankViewModel, IsDesignTimeCreatable=True}"
    d:DesignHeight="600"
    d:DesignWidth="1048"
    mc:Ignorable="d">

    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:EventToCommand EventName="Loaded" Command="{Binding LoadedCommand}" />
    </dxmvvm:Interaction.Behaviors>

    <DockPanel Margin="{StaticResource ff.PanelPaddingThickness}">

        <!-- ── Summary + controls bar ─────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Style="{StaticResource ff.PanelControlStyle}"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Financial summary -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="Cash: " Style="{StaticResource ff.SmallStyle}"/>
                        <TextBlock Text="{Binding CashText}"
                                   Style="{StaticResource ff.BodyStrongStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="Total value: " Style="{StaticResource ff.SmallStyle}"/>
                        <TextBlock Text="{Binding TotalValueText}"
                                   Style="{StaticResource ff.BodyStrongStyle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="P&amp;L: " Style="{StaticResource ff.SmallStyle}"/>
                        <TextBlock Text="{Binding PnlText}"
                                   Style="{StaticResource ff.BodyStrongStyle}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sim time + controls -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <TextBlock Text="Sim time: " Style="{StaticResource ff.SmallStyle}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SimTimeText}"
                               Style="{StaticResource ff.BodyStyle}"
                               VerticalAlignment="Center"/>

                    <Button Command="{Binding TickDayCommand}"
                            Style="{StaticResource ff.ButtonStyle}"
                            Padding="12,4"
                            Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Tick day" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SettleNowCommand}"
                            Style="{StaticResource ff.ButtonStyle}"
                            Padding="12,4"
                            Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8AB;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" Settle now" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Bottom buttons ──────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding ReloadCsvCommand}"
                        Style="{StaticResource ff.ButtonFlatStyle}"
                        Padding="12,4"
                        Content="Reload positions.csv"/>
                <Button Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource ff.ButtonFlatStyle}"
                        Padding="12,4"
                        Margin="8,0,0,0"
                        Content="Export positions.csv"/>
            </StackPanel>
        </Border>

        <!-- ── Holdings / Orders splitter + Ledger ────────────────── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Holdings (left) + Orders (right) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Holdings -->
                <Border Grid.Column="0" Style="{StaticResource ff.PanelStyle}" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Holdings"
                                   Style="{StaticResource ff.SubheaderStyle}"
                                   Margin="12,8,12,4"/>
                        <DataGrid ItemsSource="{Binding Holdings}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fund" Binding="{Binding FundName}" Width="*"/>
                                <DataGridTextColumn Header="Units" Binding="{Binding Units, StringFormat=N2}" Width="80"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding CurrentValue.Amount, StringFormat=N0}" Width="90"/>
                                <DataGridTextColumn Header="P&amp;L %" Binding="{Binding GainLossPercent, StringFormat=N1}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Style="{StaticResource ff.SplitterStyle}"/>

                <!-- Pending orders -->
                <Border Grid.Column="2" Style="{StaticResource ff.PanelStyle}" Padding="0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Pending orders"
                                   Style="{StaticResource ff.SubheaderStyle}"
                                   Margin="12,8,12,4"/>
                        <DataGrid ItemsSource="{Binding PendingOrders}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  FontSize="12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type" Binding="{Binding Side}" Width="60"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding AmountValue, StringFormat=N0}" Width="90"/>
                                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=MM-dd HH:mm}" Width="90"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="{StaticResource MahApps.Brushes.Gray7}"/>

            <!-- Ledger (double-entry) -->
            <Border Grid.Row="2" Style="{StaticResource ff.PanelStyle}" Padding="0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Ledger (double-entry)"
                               Style="{StaticResource ff.SubheaderStyle}"
                               Margin="12,8,12,4"/>
                    <DataGrid ItemsSource="{Binding LedgerRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="130"/>
                            <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="*"/>
                            <DataGridTextColumn Header="Dr" Binding="{Binding Debit}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Cr" Binding="{Binding Credit}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Memo" Binding="{Binding Memo}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>
</UserControl>

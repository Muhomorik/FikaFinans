<mah:MetroWindow
    x:Class="FikaFinans.Wpf.Views.Dialogs.FundDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:FikaFinans.Wpf.ViewModels"
    Title="{Binding WindowTitle}"
    Width="800"
    Height="640"
    MinWidth="600"
    MinHeight="400"
    d:DataContext="{d:DesignInstance Type=viewModels:FundDetailViewModel, IsDesignTimeCreatable=True}"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <DockPanel Margin="16">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="{StaticResource ff.LabelSpacing}">
            <TextBlock Text="{Binding FundIsin}" Style="{StaticResource ff.TitleStyle}"/>
            <TextBlock Text="{Binding FundName}" Style="{StaticResource ff.SubheaderStyle}"/>
        </StackPanel>

        <!-- 10 step sections (accordion-like, one per step) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ff.PanelControlStyle}"
                                Margin="{StaticResource ff.CompactSpacing}"
                                Padding="8">
                            <Expander IsExpanded="True">
                                <Expander.Header>
                                    <TextBlock>
                                        <Run Text="{Binding StepNumber, Mode=OneWay, StringFormat='Step {0} · '}"/>
                                        <Run Text="{Binding AgentName, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </Expander.Header>
                                <TextBlock Text="{Binding Content}"
                                           Style="{StaticResource ff.SmallStyle}"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap"
                                           Margin="{StaticResource ff.CompactSpacing}"/>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</mah:MetroWindow>
